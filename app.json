{
  "expo": {
    "name": "Nova",
    "slug": "nova",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "nova",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-audio",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Nova uses the camera so you can capture clear left and right palm photos for symbolic readings.",
          "photosPermission": "Nova uses your photo library so you can choose left and right palm photos for symbolic readings."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
